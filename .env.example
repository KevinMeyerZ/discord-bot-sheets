# Discord Bot Token
# Get this from: https://discord.com/developers/applications
# Go to your bot → Bot → Token
TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# Google Sheet Name
# The name of your Google Sheet (default: Database Discord)
# Make sure the sheet is shared with your service account email
SHEET_NAME=Data Member RTA

# Optional: If you want to use credentials as environment variable
# Copy the entire contents of your credentials.json file here
# GOOGLE_CREDENTIALS={"type":"service_account","project_id":"..."}
